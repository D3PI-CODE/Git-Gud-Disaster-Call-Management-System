# Project URL (not /rest/v1/)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Service role / secret key (server only — never put in Frontend)
SUPABASE_KEY=your-service-role-or-secret-key

# Optional: run python setup_schema.py
# DATABASE_URL=postgresql://postgres.YOUR_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
# SUPABASE_DB_PASSWORD=your-database-password
# SUPABASE_PROJECT_REF=YOUR_PROJECT_REF

GEMINI_API_KEY=your-gemini-api-key
VALSEA_API_KEY=your-valsea-api-key
