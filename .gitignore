# ================================
# OS & Editor (Applied Globally)
# ================================
.DS_Store
Thumbs.db
Desktop.ini
.idea/
*.suo
.ntvs
*.njsproj
*.sln
*.sw?

# VS Code specific
.vscode/
!.vscode/extensions.json
!.vscode/settings.json

# ================================
# Environment & Secrets
# ================================
# This matches .env files anywhere in the project
.env
.env.*
!.env.example
*.pem
*.key

# ================================
# Python / Backend (Specific to Backend folder)
# ================================
Backend/__pycache__/
Backend/*.py[cod]
Backend/.venv/
Backend/venv/
Backend/env/
Backend/dist/
Backend/build/
Backend/*.egg-info/
Backend/.pytest_cache/
Backend/.mypy_cache/

# ================================
# Frontend (Specific to Frontend folder)
# ================================
Frontend/node_modules/
Frontend/.eslintcache
Frontend/dist/
Frontend/.prettierignore

# ================================
# Logs & Debug
# ================================
logs/
*.log
npm-debug.log*
yarn-debug.log*